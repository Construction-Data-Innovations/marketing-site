---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingNav from '../components/landing/LandingNav.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';
import WaitlistIsland from '../components/WaitlistIsland.tsx';
---
<BaseLayout title="Solutions - ConstructWise">
  <div class="min-h-screen bg-white pt-16">
    <LandingNav />

    <!-- Hero Section -->
    <section class="py-20 bg-gradient-to-br from-blue-50 to-white">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">
          Created for Every Builder by Builders
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto m-4">
          Go from unstructured files and takeoffs to comprehensive, detailed cost estimates and Gantt chart schedules in minutes
        </p>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto m-4">
          When a firm joins ConstructWise, we ingest their historical cost proposals, P&amp;Ls, CPM schedules, and unit rates. The AI adapts to their methods &ndash; not the other way around.
        </p>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto m-4">
          So when they upload their data, the system doesn't spit out generic analysis. It generates a 70%-complete, detailed cost estimate with matching baseline schedule, as if their seasoned estimators had created the draft. Construction teams can then refine it with AI-powered queries, but the baseline already fits their process.
        </p>
      </div>
    </section>

    <!-- Cost Estimators Section -->
    <section class="py-20 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="order-2 md:order-1">
            <div class="inline-flex items-center justify-center p-3 bg-blue-100 rounded-lg mb-4">
              <!-- Calculator icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-blue-600"><rect width="16" height="20" x="4" y="2" rx="2"></rect><line x1="8" x2="16" y1="6" y2="6"></line><line x1="16" x2="16" y1="14" y2="18"></line><path d="M16 10h.01"></path><path d="M12 10h.01"></path><path d="M8 10h.01"></path><path d="M12 14h.01"></path><path d="M8 14h.01"></path><path d="M12 18h.01"></path><path d="M8 18h.01"></path></svg>
            </div>
            <h2 class="text-3xl font-bold mb-4">Cost Estimating</h2>
            <p class="text-lg text-gray-600 mb-6">
              Build detailed cost estimates with intelligent forecasts and real-time collaboration
            </p>
            <ul class="space-y-3 mb-6">
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>AI-powered cost proposal where you always remain in the driver's seat</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Not just automation &ndash; customization that preserves your company's secret sauce while making your team exponentially faster</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Simulate real-world scenarios, then choose your plans according to your risk level</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Historical data integration for more accurate forecasting</span>
              </li>
            </ul>
          </div>
          <div class="order-1 md:order-2 bg-white rounded-xl p-6 shadow-lg">
            <div class="aspect-video bg-white rounded-lg overflow-hidden">
              <svg viewBox="0 0 560 315" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                <rect width="560" height="315" fill="white"/>
                <!-- Header -->
                <rect x="20" y="16" width="520" height="36" rx="6" fill="#f8fafc"/>
                <rect x="32" y="26" width="90" height="16" rx="4" fill="#2563eb"/>
                <rect x="138" y="26" width="60" height="16" rx="4" fill="#e2e8f0"/>
                <rect x="214" y="26" width="60" height="16" rx="4" fill="#e2e8f0"/>
                <!-- Upload area with document icon -->
                <rect x="20" y="64" width="260" height="100" rx="8" fill="#fafbfd" stroke="#e2e8f0" stroke-width="1" stroke-dasharray="6 3"/>
                <text x="100" y="100" font-family="system-ui" font-size="10" fill="#94a3b8">SOW Document</text>
                <rect x="80" y="108" width="120" height="6" rx="3" fill="#2563eb"/>
                <rect x="80" y="118" width="120" height="6" rx="3" fill="#e2e8f0"/>
                <rect x="80" y="118" width="96" height="6" rx="3" fill="#60a5fa"/>
                <text x="90" y="142" font-family="system-ui" font-size="9" fill="#22c55e">Uploaded &amp; Analyzed</text>
                <!-- Arrow -->
                <text x="294" y="114" font-family="system-ui" font-size="20" fill="#2563eb">&rarr;</text>
                <!-- Generated estimate preview -->
                <rect x="320" y="64" width="220" height="100" rx="8" fill="#eff6ff" stroke="#bfdbfe" stroke-width="1"/>
                <text x="336" y="84" font-family="system-ui" font-size="10" font-weight="600" fill="#1e40af">Generated Estimate</text>
                <rect x="336" y="92" width="140" height="5" rx="2" fill="#bfdbfe"/>
                <rect x="336" y="102" width="188" height="5" rx="2" fill="#dbeafe"/>
                <rect x="336" y="112" width="160" height="5" rx="2" fill="#dbeafe"/>
                <rect x="336" y="126" width="80" height="16" rx="4" fill="#2563eb"/>
                <text x="348" y="138" font-family="system-ui" font-size="8" fill="white">70% Complete</text>
                <text x="336" y="156" font-family="system-ui" font-size="8" fill="#64748b">Ready for your review</text>
                <!-- Three summary cards -->
                <rect x="20" y="178" width="168" height="68" rx="8" fill="white" stroke="#e2e8f0" stroke-width="1"/>
                <text x="32" y="198" font-family="system-ui" font-size="9" fill="#94a3b8">Direct Costs</text>
                <text x="32" y="218" font-family="system-ui" font-size="16" font-weight="700" fill="#1e3a5f">$1.84M</text>
                <text x="32" y="234" font-family="system-ui" font-size="8" fill="#22c55e">-8% vs. avg</text>
                <rect x="196" y="178" width="168" height="68" rx="8" fill="white" stroke="#e2e8f0" stroke-width="1"/>
                <text x="208" y="198" font-family="system-ui" font-size="9" fill="#94a3b8">Risk Score</text>
                <text x="208" y="218" font-family="system-ui" font-size="16" font-weight="700" fill="#f59e0b">Medium</text>
                <text x="208" y="234" font-family="system-ui" font-size="8" fill="#78716c">3 items flagged</text>
                <rect x="372" y="178" width="168" height="68" rx="8" fill="white" stroke="#e2e8f0" stroke-width="1"/>
                <text x="384" y="198" font-family="system-ui" font-size="9" fill="#94a3b8">Confidence</text>
                <text x="384" y="218" font-family="system-ui" font-size="16" font-weight="700" fill="#22c55e">94%</text>
                <text x="384" y="234" font-family="system-ui" font-size="8" fill="#78716c">12 similar projects</text>
                <!-- Bottom bar -->
                <rect x="20" y="260" width="520" height="36" rx="8" fill="#f0fdf4" stroke="#bbf7d0" stroke-width="1"/>
                <text x="36" y="282" font-family="system-ui" font-size="10" fill="#166534">Your historical pricing applied &mdash; estimates match your company's cost structure</text>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Schedule Building Section -->
    <section class="py-20">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="bg-gray-100 rounded-xl p-6 shadow-inner">
            <div class="aspect-video bg-white rounded-lg shadow-lg overflow-hidden">
              <svg viewBox="0 0 560 315" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                <rect width="560" height="315" fill="white"/>
                <!-- Header -->
                <rect x="20" y="16" width="520" height="36" rx="6" fill="#f8fafc"/>
                <rect x="32" y="26" width="100" height="16" rx="4" fill="#2563eb"/>
                <rect x="148" y="26" width="60" height="16" rx="4" fill="#e2e8f0"/>
                <!-- WBS Column -->
                <rect x="20" y="64" width="30" height="24" rx="4" fill="#eff6ff"/>
                <text x="28" y="80" font-family="system-ui" font-size="8" font-weight="600" fill="#1e40af">WBS</text>
                <rect x="54" y="64" width="116" height="24" rx="4" fill="#eff6ff"/>
                <text x="62" y="80" font-family="system-ui" font-size="9" font-weight="600" fill="#1e40af">Activity Name</text>
                <!-- Timeline -->
                <text x="190" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 1</text>
                <text x="238" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 2</text>
                <text x="286" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 3</text>
                <text x="334" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 4</text>
                <text x="382" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 5</text>
                <text x="430" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 6</text>
                <text x="478" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 7</text>
                <text x="526" y="80" font-family="system-ui" font-size="8" fill="#94a3b8">Wk 8</text>
                <!-- Grid -->
                <line x1="180" y1="64" x2="180" y2="250" stroke="#f1f5f9" stroke-width="1"/>
                <line x1="228" y1="88" x2="228" y2="250" stroke="#f1f5f9" stroke-width="1" stroke-dasharray="3 3"/>
                <line x1="276" y1="88" x2="276" y2="250" stroke="#f1f5f9" stroke-width="1" stroke-dasharray="3 3"/>
                <line x1="324" y1="88" x2="324" y2="250" stroke="#f1f5f9" stroke-width="1" stroke-dasharray="3 3"/>
                <line x1="372" y1="88" x2="372" y2="250" stroke="#f1f5f9" stroke-width="1" stroke-dasharray="3 3"/>
                <line x1="420" y1="88" x2="420" y2="250" stroke="#f1f5f9" stroke-width="1" stroke-dasharray="3 3"/>
                <line x1="468" y1="88" x2="468" y2="250" stroke="#f1f5f9" stroke-width="1" stroke-dasharray="3 3"/>
                <!-- Activities with WBS -->
                <text x="28" y="106" font-family="system-ui" font-size="8" fill="#94a3b8">1.1</text>
                <text x="62" y="106" font-family="system-ui" font-size="9" fill="#475569">Mobilization</text>
                <rect x="190" y="96" width="48" height="14" rx="3" fill="#ef4444"/>
                <text x="28" y="128" font-family="system-ui" font-size="8" fill="#94a3b8">1.2</text>
                <text x="62" y="128" font-family="system-ui" font-size="9" fill="#475569">Excavation</text>
                <rect x="232" y="118" width="60" height="14" rx="3" fill="#ef4444"/>
                <text x="28" y="150" font-family="system-ui" font-size="8" fill="#94a3b8">2.1</text>
                <text x="62" y="150" font-family="system-ui" font-size="9" fill="#475569">Foundations</text>
                <rect x="286" y="140" width="72" height="14" rx="3" fill="#ef4444"/>
                <text x="28" y="172" font-family="system-ui" font-size="8" fill="#94a3b8">2.2</text>
                <text x="62" y="172" font-family="system-ui" font-size="9" fill="#475569">Underground MEP</text>
                <rect x="310" y="162" width="60" height="14" rx="3" fill="#93c5fd"/>
                <text x="28" y="194" font-family="system-ui" font-size="8" fill="#94a3b8">3.1</text>
                <text x="62" y="194" font-family="system-ui" font-size="9" fill="#475569">Steel Erection</text>
                <rect x="358" y="184" width="96" height="14" rx="3" fill="#ef4444"/>
                <text x="28" y="216" font-family="system-ui" font-size="8" fill="#94a3b8">3.2</text>
                <text x="62" y="216" font-family="system-ui" font-size="9" fill="#475569">Metal Decking</text>
                <rect x="420" y="206" width="60" height="14" rx="3" fill="#93c5fd"/>
                <text x="28" y="238" font-family="system-ui" font-size="8" fill="#94a3b8">4.1</text>
                <text x="62" y="238" font-family="system-ui" font-size="9" fill="#475569">Roofing</text>
                <rect x="468" y="228" width="72" height="14" rx="3" fill="#93c5fd"/>
                <!-- Critical path legend -->
                <rect x="20" y="260" width="520" height="40" rx="8" fill="#f8fafc"/>
                <rect x="36" y="274" width="12" height="12" rx="2" fill="#ef4444"/>
                <text x="54" y="284" font-family="system-ui" font-size="9" fill="#475569">Critical Path</text>
                <rect x="140" y="274" width="12" height="12" rx="2" fill="#93c5fd"/>
                <text x="158" y="284" font-family="system-ui" font-size="9" fill="#475569">Has Float</text>
                <text x="340" y="284" font-family="system-ui" font-size="9" font-weight="600" fill="#1e40af">Auto-generated from AI analysis</text>
              </svg>
            </div>
          </div>
          <div>
            <div class="inline-flex items-center justify-center p-3 bg-blue-100 rounded-lg mb-4">
              <!-- HardHat icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-blue-600"><path d="M2 18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v2z"></path><path d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"></path><path d="M4 15v-3a6 6 0 0 1 6-6h0"></path><path d="M14 6h0a6 6 0 0 1 6 6v3"></path></svg>
            </div>
            <h2 class="text-3xl font-bold mb-4">Schedule Building</h2>
            <p class="text-lg text-gray-600 mb-6">
              Create dynamic project schedules with intelligent dependency management and resource allocation
            </p>
            <ul class="space-y-3 mb-6">
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Interactive Gantt chart with drag-and-drop functionality</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Automatic critical path calculation and visualization</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Schedule risk analysis with simulations</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Schedules for any stage of the project lifecycle</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Assistant Section -->
    <section class="py-20 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="order-2 md:order-1">
            <div class="inline-flex items-center justify-center p-3 bg-blue-100 rounded-lg mb-4">
              <!-- Brain icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-blue-600"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"></path><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"></path><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"></path><path d="M3.477 10.896a4 4 0 0 1 .585-.396"></path><path d="M19.938 10.5a4 4 0 0 1 .585.396"></path><path d="M6 18a4 4 0 0 1-1.967-.516"></path><path d="M19.967 17.484A4 4 0 0 1 18 18"></path></svg>
            </div>
            <h2 class="text-3xl font-bold mb-4">AI Assistant</h2>
            <p class="text-lg text-gray-600 mb-6">
              Get intelligent insights and recommendations from our construction-specialized AI assistant
            </p>
            <ul class="space-y-3 mb-6">
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Construction-specific knowledge base for accurate answers</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Automated cost and schedule optimization suggestions</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Risk identification based on historical project data</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-600 mr-2">&bull;</span>
                <span>Query in natural language and visualize your data dynamically</span>
              </li>
            </ul>
          </div>
          <div class="order-1 md:order-2 bg-white rounded-xl p-6 shadow-lg">
            <div class="aspect-video bg-white rounded-lg overflow-hidden">
              <svg viewBox="0 0 560 315" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                <rect width="560" height="315" fill="white"/>
                <!-- Header -->
                <rect x="20" y="16" width="520" height="36" rx="6" fill="#f8fafc"/>
                <rect x="32" y="26" width="12" height="12" rx="6" fill="#22c55e"/>
                <text x="50" y="35" font-family="system-ui" font-size="11" font-weight="600" fill="#1e3a5f">AI Assistant</text>
                <!-- User question -->
                <rect x="240" y="68" width="300" height="30" rx="12" fill="#2563eb"/>
                <text x="256" y="87" font-family="system-ui" font-size="10" fill="white">What's the risk on the MEP scope?</text>
                <!-- AI response with risk analysis -->
                <rect x="20" y="110" width="420" height="160" rx="12" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1"/>
                <text x="36" y="132" font-family="system-ui" font-size="10" font-weight="600" fill="#1e3a5f">Risk Analysis: MEP Scope</text>
                <!-- Risk items -->
                <rect x="36" y="142" width="388" height="28" rx="6" fill="#fef2f2"/>
                <rect x="44" y="150" width="8" height="8" rx="4" fill="#ef4444"/>
                <text x="60" y="160" font-family="system-ui" font-size="9" font-weight="500" fill="#991b1b">High: Electrical subcontractor pricing 18% above market</text>
                <rect x="36" y="176" width="388" height="28" rx="6" fill="#fefce8"/>
                <rect x="44" y="184" width="8" height="8" rx="4" fill="#f59e0b"/>
                <text x="60" y="194" font-family="system-ui" font-size="9" font-weight="500" fill="#92400e">Medium: HVAC lead times extended to 14 weeks</text>
                <rect x="36" y="210" width="388" height="28" rx="6" fill="#f0fdf4"/>
                <rect x="44" y="218" width="8" height="8" rx="4" fill="#22c55e"/>
                <text x="60" y="228" font-family="system-ui" font-size="9" font-weight="500" fill="#166534">Low: Plumbing scope well-defined, 3 competitive bids</text>
                <!-- Suggestion -->
                <text x="36" y="256" font-family="system-ui" font-size="9" fill="#475569">Based on 8 similar projects, consider allocating 5%</text>
                <text x="36" y="268" font-family="system-ui" font-size="9" fill="#475569">contingency to electrical scope.</text>
                <!-- Input bar -->
                <rect x="20" y="280" width="520" height="24" rx="12" fill="white" stroke="#e2e8f0" stroke-width="1"/>
                <text x="36" y="296" font-family="system-ui" font-size="9" fill="#94a3b8">Follow up: &quot;Show me the electrical sub breakdown...&quot;</text>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial Section -->
    <section class="py-20 bg-gray-50">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="md:grid-cols-2 gap-8">
          <div class="bg-white p-6 rounded-xl shadow-md grid grid-cols-1 md:grid-cols-2">
            <div class="mx-4 m-15">
              <h3 class="text-xl mb-10">&quot;ConstructWise offloads so much of the painstaking manual processes anyone could do. It allows us to spend more time to think critically about bidding decisions and quantify how they'll impact the holistic project.&quot;</h3>
              <p class="font-bold">Jeremy Hynum</p>
              <p class="text-gray-600">Estimator, Rise Construction</p>
            </div>
            <div class="bg-gray-100 rounded-lg flex items-center justify-center p-8">
              <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full max-w-[200px]">
                <!-- Abstract construction/building graphic -->
                <rect x="30" y="60" width="50" height="110" rx="4" fill="#2563eb" opacity="0.15"/>
                <rect x="40" y="40" width="50" height="130" rx="4" fill="#2563eb" opacity="0.3"/>
                <rect x="75" y="20" width="50" height="150" rx="4" fill="#2563eb" opacity="0.5"/>
                <rect x="110" y="50" width="50" height="120" rx="4" fill="#2563eb" opacity="0.35"/>
                <rect x="120" y="70" width="50" height="100" rx="4" fill="#2563eb" opacity="0.2"/>
                <!-- Upward trend line -->
                <path d="M30 160 L70 120 L110 90 L150 40" stroke="#2563eb" stroke-width="3" stroke-linecap="round"/>
                <circle cx="150" cy="40" r="5" fill="#2563eb"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 px-4 bg-blue-600">
      <div class="container mx-auto text-center">
        <h2 class="text-4xl font-bold text-white mb-6">Elevate Your Construction Planning Today</h2>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
          Join other innovative construction companies who are leveraging ConstructWise's vertical AI to generate better cost estimates and construction schedules.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <WaitlistIsland
            client:idle
            buttonClassName="text-lg px-8 py-3 h-12"
            variant="secondary"
          />
          <a
            href="https://app.constructwise.ai"
            class="inline-flex items-center justify-center rounded-md text-lg px-8 py-3 bg-white border border-gray-400 text-black hover:bg-blue-300 duration-500 h-12 font-medium"
          >
            Early Access
          </a>
        </div>
      </div>
    </section>

