---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingNav from '../components/landing/LandingNav.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';
import WaitlistIsland from '../components/WaitlistIsland.tsx';
---
<BaseLayout>
  <div class="min-h-screen bg-gradient-to-b from-slate-50 to-white pt-20">
    <LandingNav />

    <section class="py-20 px-4">
      <div class="container mx-auto text-center max-w-4xl">
        <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">
          Intelligent Bid Estimation and Schedule Planning{" "}
          <span class="text-blue-600">for the Construction Industry</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
          Upload your historical documents, connect to your existing apps, and access AI-powered construction solutions &ndash; all in one platform
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
          <WaitlistIsland
            client:idle
            buttonClassName="text-lg px-8 py-3 h-12"
            variant="primary"
          />
          <a
            href="https://app.constructwise.ai"
            class="inline-flex items-center justify-center rounded-md text-lg px-8 py-3 bg-white border border-gray-400 text-black hover:bg-blue-300 duration-500 h-12 font-medium"
          >
            Early Access
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-3xl mx-auto">
          <div class="text-center">
            <div class="text-4xl font-bold text-blue-600 mb-2">90%</div>
            <div class="text-gray-600">Time saved generating bids</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-blue-600 mb-2">25%</div>
            <div class="text-gray-600">Increase in bid win rates</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-blue-600 mb-2">30%</div>
            <div class="text-gray-600">Reduction in costly errors</div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4 bg-gray-100">
      <div class="flex flex-col sm:flex-row gap-4 justify-center m-12 text-3xl md:text-4xl font-semibold">Complete Construction Intelligence Platform</div>
      <p class="text-2xl text-center text-gray-600 mb-8 max-w-3xl mx-auto">From initial planning to project completion, ConstructWise provides AI-powered solutions for your numeric bid &amp; schedule data</p>
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-xl shadow-md border border-gray-100">
            <!-- ChartColumn icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chart-column h-12 w-12 text-blue-600" aria-hidden="true"><path d="M3 3v16a2 2 0 0 0 2 2h16"></path><path d="M18 17V9"></path><path d="M13 17V5"></path><path d="M8 17v-3"></path></svg>
            <div class="text-xl font-semibold my-2">Cost Estimates</div>
            <p class="text-gray-600">AI-powered cost breakdowns with risk analysis and optimization suggestions</p>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-md border border-gray-100">
            <!-- CalendarCheck2 icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 text-blue-600"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path><path d="m9 16 2 2 4-4"></path></svg>
            <div class="text-xl font-semibold my-2">Schedules</div>
            <p class="text-gray-600">No more manually typing schedule activities in P6 or MS Project with complicated WBS, dependencies, and resources. Streamline critical path scheduling and then query your schedule.</p>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-md border border-gray-100">
            <!-- User icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 text-blue-600"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            <div class="text-xl font-semibold my-2">Forecasting</div>
            <p class="text-gray-600">Predictive analytics in a whole new light</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="container mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-4xl font-bold text-gray-900 mb-6">Generate High Quality Cost Estimates</h2>
            <p class="text-lg text-gray-600 mb-8">
              Transform your proposal process with ConstructWise's advanced AI engine. Generate comprehensive, tailored proposals in minutes instead of days.
            </p>
            <div class="space-y-4 mb-8">
              <div class="flex items-center space-x-3">
                <div class="text-2xl font-bold text-blue-600 mb-2">10x faster</div>
                <span class="text-gray-700">Than traditional methods</span>
              </div>
              <div class="flex items-center space-x-3">
                <div class="text-2xl font-bold text-blue-600 mb-2">30% higher</div>
                <span class="text-gray-700">Win rate for clients</span>
              </div>
            </div>
          </div>
          <div class="bg-gray-100 rounded-xl p-6 shadow-inner">
            <div class="aspect-video bg-white rounded-lg shadow-lg overflow-hidden">
              <div class="p-4">
                <div class="p-4">
                  <div class="h-8 bg-blue-100 rounded-md w-1/3 mb-4"></div>
                  <div class="grid grid-cols-2 gap-4 mb-4">
                    <div class="h-32 bg-red-50 rounded-md"></div>
                    <div class="h-32 bg-yellow-50 rounded-md"></div>
                  </div>
                  <div class="h-24 bg-blue-50 rounded-md w-full"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4 bg-gray-100">
      <div class="container mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="bg-white rounded-xl p-6 shadow-lg">
            <div class="aspect-video bg-white rounded-lg overflow-hidden">
              <div class="p-4">
                <div class="h-8 bg-blue-100 rounded-md w-1/3 mb-4"></div>
                <div class="grid grid-cols-2 gap-4 mb-4">
                  <div class="h-32 bg-blue-50 rounded-md"></div>
                  <div class="h-32 bg-green-50 rounded-md"></div>
                </div>
                <div class="h-24 bg-gray-100 rounded-md w-full"></div>
              </div>
            </div>
          </div>
          <div>
            <h2 class="text-4xl font-bold text-gray-900 mb-6">Construction Schedule Optimization</h2>
            <p class="text-lg text-gray-600 mb-8">
              Leverage our intelligence platform to create and optimize construction schedules based on your company's historical data. Model your timelines, resource needs, and potential risks before making decisions.
            </p>
            <div class="space-y-4 mb-8">
              <div class="flex items-center space-x-3">
                <div class="text-2xl font-bold text-blue-600 mb-2">95% accuracy</div>
                <span class="text-gray-700">In timeline predictions</span>
              </div>
              <div class="flex items-center space-x-3">
                <div class="text-2xl font-bold text-blue-600 mb-2">40% reduction</div>
                <span class="text-gray-700">In project delays</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4">
      <div class="container mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-4xl font-bold text-gray-900 mb-6">Seamless Integration &amp; Actionable Insights</h2>
            <p class="text-lg text-gray-600 mb-8">
              Connect to your existing apps and pull your relevant construction data into one place. Get actionable insights through ConstructWise's conversational chat to make better decisions, based on your company's own job histories
            </p>
            <div class="space-y-4 mb-8">
              <div class="flex items-center space-x-3">
                <div class="text-2xl font-bold text-blue-600 mb-2">Multiple Integrations</div>
                <span class="text-gray-700">With popular construction apps</span>
              </div>
              <div class="flex items-center space-x-3">
                <div class="text-2xl font-bold text-blue-600 mb-2">Actionable insights</div>
                <span class="text-gray-700">From all your historical bid and project data</span>
              </div>
            </div>
          </div>
          <div class="bg-gray-100 rounded-xl p-6 shadow-inner">
            <div class="aspect-video bg-white rounded-lg shadow-lg overflow-hidden">
              <div class="p-4">
                <div class="h-8 bg-blue-100 rounded-md w-1/3 mb-4"></div>
                <div class="grid grid-cols-2 gap-4 mb-4">
                  <div class="h-32 bg-blue-50 rounded-md"></div>
                  <div class="h-32 bg-green-50 rounded-md"></div>
                </div>
                <div class="h-24 bg-gray-100 rounded-md w-full"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4 bg-gray-100">
      <div class="container mx-auto">
        <div class="flex justify-center items-center">
          <h2 class="text-4xl font-bold text-gray-900 mb-10">How to Get Started</h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-center">
          <div class="flex flex-col items-center">
            <div class="w-[60px] h-[60px] text-2xl font-bold bg-blue-600 text-white rounded-full flex items-center justify-center mb-4">
              1
            </div>
            <h2 class="text-4xl font-semibold text-gray-900 mb-6 text-center">Start for free</h2>
            <p class="text-lg text-gray-600 mb-8 text-center">
              Sign up and be first on the waitlist to use ConstructWise as your trusted, daily cost proposal and schedule management platform.
            </p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-[60px] h-[60px] text-2xl font-bold bg-blue-600 text-white rounded-full flex items-center justify-center mb-4">
              2
            </div>
            <h2 class="text-4xl font-semibold text-gray-900 mb-6 text-center">Connect &amp; upload</h2>
            <p class="text-lg text-gray-600 mb-8 text-center">
              Upload your historical construction files and connect to your existing apps to gain deeper understanding of your data.
            </p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-[60px] h-[60px] text-2xl font-bold bg-blue-600 text-white rounded-full flex items-center justify-center mb-4">
              3
            </div>
            <h2 class="text-4xl font-semibold text-gray-900 mb-6 text-center">Generate &amp; optimize</h2>
            <p class="text-lg text-gray-600 mb-8 text-center max-w-md">
              Create accurate cost estimates and optimized construction schedules with our intelligence platform.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 px-4 bg-blue-600">
      <div class="container mx-auto text-center">
        <h2 class="text-4xl font-bold text-white mb-6">Elevate Your Construction Planning Today</h2>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
          Join other innovative construction companies who are leveraging ConstructWise's vertical AI to generate better cost estimates and construction schedules.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <WaitlistIsland
            client:idle
            buttonClassName="text-lg px-8 py-3 h-12"
            variant="secondary"
          />
          <a
            href="https://app.constructwise.ai"
            class="inline-flex items-center justify-center rounded-md text-lg px-8 py-3 bg-white border border-gray-400 text-black hover:bg-blue-300 duration-500 h-12 font-medium"
          >
            Early Access
          </a>
        </div>
      </div>
    </section>

    <LandingFooter />
  </div>
</BaseLayout>
